{
  "api_key_env": "OPENAI_API_KEY",
  "enabled": false,
  "endpoint": "https://api.openai.com/v1/responses",
  "execute_tools": false,
  "apply_model_writes": true,
  "generation_mode": "ai_assisted_controlled",
